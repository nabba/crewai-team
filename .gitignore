.env
.env.*
!.env.example
workspace/memory/
workspace/output/
workspace/affect/
workspace/skills/*.md
!workspace/skills/learning_queue.md
# Versioned prompt registry — tracked for version history and rollback
!workspace/prompts/
__pycache__/
*.pyc
.pytest_cache/
*.egg-info/
dist/
.venv/
*.log
.DS_Store
*.pem
*.key
*.p12
*.pfx
firebase-service-account.json
# Host Bridge — capability tokens contain secrets
host_bridge/capabilities.json

# Wiki lock files (transient)
wiki/.locks/*.lock
# Compiled CoreLocation helper binary
signal/location-helper
wiki/.slides/

# ── Workspace runtime state (Phase A3 hygiene) ─────────────────────────
# These files are written continuously by background jobs and the CIL loop.
# They represent transient state, not source-of-truth knowledge.
# Existing tracked instances are not removed by this pattern (use
# `git rm --cached <path>` if you want to stop tracking them); this only
# prevents NEW transient writes from being committed accidentally.
workspace/.workspace.lock
workspace/.locks/
workspace/.self_knowledge_hashes.json
workspace/SYSTEM_AUDIT_*.md
workspace/agent_state.json
workspace/alignment_audits.json
workspace/audit_journal.json
workspace/benchmarks.json
workspace/error_tracker.json
workspace/homeostasis.json
workspace/atlas/competence/competence_map.json
workspace/island_evolution/*/state.json
workspace/checkpoints/
workspace/cache/
workspace/experiential/*/length.bin
