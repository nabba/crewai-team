rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Dashboard collections — public read, backend-only write
    match /status/{doc}     { allow read: if true; allow write: if false; }
    match /crews/{doc}      { allow read: if true; allow write: if false; }
    match /tasks/{doc}      { allow read: if true; allow write: if false; }
    match /activities/{doc} { allow read: if true; allow write: if false; }
    match /schedule/{doc}   { allow read: if true; allow write: if false; }

    // Config — public read/write (dashboard mode switch)
    // Write is limited to known fields via validation
    match /config/{doc}     {
      allow read: if true;
      allow write: if request.resource.data.keys().hasOnly(['mode', 'updated_at'])
                   && request.resource.data.mode in ['local', 'cloud', 'hybrid', 'insane'];
    }

    // Deny everything else
    match /{document=**} { allow read, write: if false; }
  }
}
