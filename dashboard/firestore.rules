rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Dashboard collections — public read, backend-only write (admin SDK)
    match /status/{doc}     { allow read: if true; allow write: if false; }
    match /crews/{doc}      { allow read: if true; allow write: if false; }
    match /tasks/{doc}      { allow read: if true; allow write: if false; }
    match /activities/{doc} { allow read: if true; allow write: if false; }
    match /schedule/{doc}   { allow read: if true; allow write: if false; }

    // Config — dashboard controls with strict field validation.
    // Auth guard: request.auth != null when Anonymous Auth is enabled in
    // Firebase Console; until then, field validation provides the safety net.
    match /config/llm {
      allow read: if true;
      allow write: if request.resource.data.keys().hasOnly(['mode', 'updated_at'])
                   && request.resource.data.mode in ['local', 'cloud', 'hybrid', 'insane'];
    }
    match /config/background_tasks {
      allow read: if true;
      allow write: if request.resource.data.keys().hasOnly(['enabled', 'updated_at'])
                   && request.resource.data.enabled is bool;
    }

    // KB upload/delete queue — dashboard creates pending docs, backend processes.
    // Field validation: must have status='pending', prevents arbitrary writes.
    match /kb_queue/{doc} {
      allow read: if true;
      allow create: if request.resource.data.status == 'pending';
      allow update: if true;  // backend (admin SDK) updates status to done/error
    }

    // Philosophy KB upload queue — dashboard creates pending docs, backend processes.
    match /phil_queue/{doc} {
      allow read: if true;
      allow create: if request.resource.data.status == 'pending';
      allow update: if true;  // backend (admin SDK) updates status to done/error
    }

    // Fiction inspiration upload queue — dashboard creates pending docs, backend processes.
    match /fiction_queue/{doc} {
      allow read: if true;
      allow create: if request.resource.data.status == 'pending';
      allow update: if true;  // backend (admin SDK) updates status to done/error
    }

    // Proposal actions — dashboard creates approve/reject/rollback actions.
    // Strict field validation: must have proposal_id, action (enum), status='pending'.
    match /proposal_actions/{doc} {
      allow read: if true;
      allow create: if request.resource.data.status == 'pending'
                    && request.resource.data.action in ['approve', 'reject', 'rollback']
                    && request.resource.data.keys().hasAll(['proposal_id', 'action', 'status']);
      allow update: if true;  // backend (admin SDK) updates status to done/error
    }

    // Chat messages — backend writes, dashboard reads
    match /chat_messages/{doc} {
      allow read: if true;
      allow write: if false;  // backend-only via admin SDK
    }

    // Chat inbox — dashboard creates pending messages, backend processes them.
    // Strong validation: required fields, string type, size limit (4000 chars).
    match /chat_inbox/{doc} {
      allow read: if true;
      allow create: if request.resource.data.status == 'pending'
                    && request.resource.data.keys().hasAll(['text', 'status', 'ts'])
                    && request.resource.data.text is string
                    && request.resource.data.text.size() > 0
                    && request.resource.data.text.size() <= 4000;
      allow update: if true;  // backend (admin SDK) updates status to done/error
    }

    // Deny everything else
    match /{document=**} { allow read, write: if false; }
  }
}
