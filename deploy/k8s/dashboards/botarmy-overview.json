{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "type": "row",
      "title": "Gateway",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false
    },
    {
      "type": "stat",
      "title": "Gateway pods up",
      "datasource": { "type": "prometheus", "uid": "$datasource" },
      "targets": [{ "expr": "sum(up{job=~\".*botarmy.*-gateway\"})", "refId": "A" }],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red",   "value": null },
              { "color": "green", "value": 1 }
            ]
          },
          "unit": "none"
        }
      },
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 1 }
    },
    {
      "type": "stat",
      "title": "Request rate (rps)",
      "datasource": { "type": "prometheus", "uid": "$datasource" },
      "targets": [{ "expr": "sum(rate(http_requests_total{job=~\".*botarmy.*-gateway\"}[1m]))", "refId": "A" }],
      "fieldConfig": { "defaults": { "unit": "reqps" } },
      "gridPos": { "h": 4, "w": 5, "x": 4, "y": 1 }
    },
    {
      "type": "stat",
      "title": "5xx rate",
      "datasource": { "type": "prometheus", "uid": "$datasource" },
      "targets": [{
        "expr": "sum(rate(http_requests_total{job=~\".*botarmy.*-gateway\",status=~\"5..\"}[5m])) / sum(rate(http_requests_total{job=~\".*botarmy.*-gateway\"}[5m]))",
        "refId": "A"
      }],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null },
              { "color": "yellow", "value": 0.01 },
              { "color": "red",    "value": 0.05 }
            ]
          }
        }
      },
      "gridPos": { "h": 4, "w": 5, "x": 9, "y": 1 }
    },
    {
      "type": "stat",
      "title": "p95 latency",
      "datasource": { "type": "prometheus", "uid": "$datasource" },
      "targets": [{
        "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket{job=~\".*botarmy.*-gateway\"}[5m])) by (le))",
        "refId": "A"
      }],
      "fieldConfig": { "defaults": { "unit": "s" } },
      "gridPos": { "h": 4, "w": 5, "x": 14, "y": 1 }
    },
    {
      "type": "stat",
      "title": "Memory used / limit",
      "datasource": { "type": "prometheus", "uid": "$datasource" },
      "targets": [{
        "expr": "max(container_memory_working_set_bytes{pod=~\".*botarmy.*-gateway-.*\"}) / max(container_spec_memory_limit_bytes{pod=~\".*botarmy.*-gateway-.*\"})",
        "refId": "A"
      }],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null },
              { "color": "yellow", "value": 0.7 },
              { "color": "red",    "value": 0.85 }
            ]
          }
        }
      },
      "gridPos": { "h": 4, "w": 5, "x": 19, "y": 1 }
    },

    {
      "type": "row",
      "title": "LLM cascade",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "collapsed": false
    },
    {
      "type": "timeseries",
      "title": "LLM requests by tier",
      "datasource": { "type": "prometheus", "uid": "$datasource" },
      "targets": [{
        "expr": "sum(rate(llm_requests_total[1m])) by (tier)",
        "refId": "A",
        "legendFormat": "{{ tier }}"
      }],
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 }
    },
    {
      "type": "timeseries",
      "title": "LLM p95 latency by tier",
      "datasource": { "type": "prometheus", "uid": "$datasource" },
      "targets": [{
        "expr": "histogram_quantile(0.95, sum(rate(llm_request_duration_seconds_bucket[5m])) by (le, tier))",
        "refId": "A",
        "legendFormat": "{{ tier }}"
      }],
      "fieldConfig": { "defaults": { "unit": "s" } },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 }
    },

    {
      "type": "row",
      "title": "Memory backends",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 14 },
      "collapsed": false
    },
    {
      "type": "stat",
      "title": "Postgres up",
      "datasource": { "type": "prometheus", "uid": "$datasource" },
      "targets": [{
        "expr": "max(up{job=~\".*botarmy.*-postgres\"}) or vector(1)",
        "refId": "A"
      }],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          }
        }
      },
      "gridPos": { "h": 4, "w": 8, "x": 0, "y": 15 }
    },
    {
      "type": "stat",
      "title": "Neo4j up",
      "datasource": { "type": "prometheus", "uid": "$datasource" },
      "targets": [{ "expr": "max(up{job=~\".*botarmy.*-neo4j\"})", "refId": "A" }],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          }
        }
      },
      "gridPos": { "h": 4, "w": 8, "x": 8, "y": 15 }
    },
    {
      "type": "stat",
      "title": "ChromaDB up",
      "datasource": { "type": "prometheus", "uid": "$datasource" },
      "targets": [{ "expr": "max(up{job=~\".*botarmy.*-chromadb\"})", "refId": "A" }],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          }
        }
      },
      "gridPos": { "h": 4, "w": 8, "x": 16, "y": 15 }
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["botarmy"],
  "templating": {
    "list": [
      {
        "current": { "text": "default", "value": "default" },
        "hide": 0,
        "includeAll": false,
        "label": "Datasource",
        "multi": false,
        "name": "datasource",
        "options": [],
        "query": "prometheus",
        "refresh": 1,
        "skipUrlSync": false,
        "type": "datasource"
      }
    ]
  },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "",
  "title": "BotArmy — Overview",
  "uid": "botarmy-overview",
  "version": 1,
  "weekStart": ""
}
