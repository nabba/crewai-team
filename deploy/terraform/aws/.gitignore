# Local terraform state and dependencies
.terraform/
*.tfstate
*.tfstate.*
*.tfplan
crash.log
crash.*.log

# Sensitive — contains API keys
terraform.tfvars
terraform.auto.tfvars
*.tfvars.local

# But DO commit the example
!terraform.tfvars.example

# CLI override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Lock file is committed (per HashiCorp's recommendation)
!.terraform.lock.hcl
