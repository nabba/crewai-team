# ─── LLM Provider ─────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ─── Search ──────────────────────────────────────────────
BRAVE_API_KEY=your_brave_search_api_key_here
# Get free key at: https://api.search.brave.com/

# ─── Paid B2B / LinkedIn data adapters (OPTIONAL) ───────
# When set, the research crew's matrix-orchestrator automatically
# routes through these adapters BEFORE falling back to free SERP
# scraping. Empty values mean the adapter is registered but inert
# (graceful degradation — no crash, just less coverage).
#
# Apollo.io — Head of Sales / VP Sales / CRO names + LinkedIn URLs
# + (tier-dependent) work emails. Best for "find Sales leader at
# company X" tasks. ~$59/mo basic plan.
# Get key at: https://apollo.io/settings/api
APOLLO_API_KEY=
#
# Proxycurl — personal LinkedIn URL lookup without scraping.
# Pay-per-call (~$0.01-$0.03 per profile). Best for resolving
# personal LinkedIn URLs when Apollo doesn't have the contact.
# Get key at: https://nubela.co/proxycurl/api-keys
PROXYCURL_API_KEY=
#
# After adding either key, restart the gateway:
#   docker compose up -d gateway
# (env vars only enter the container at start; running containers
#  don't see edits to .env until they're recreated.)

# ─── Signal ──────────────────────────────────────────────
SIGNAL_BOT_NUMBER=+1XXXXXXXXXX        # Bot's dedicated phone number
SIGNAL_OWNER_NUMBER=+1XXXXXXXXXX      # Your personal iPhone number
SIGNAL_CLI_PATH=/opt/homebrew/bin/signal-cli
SIGNAL_SOCKET_PATH=/tmp/signal-cli.sock
# Host path where signal-cli stores received attachments.  Mounted into the
# gateway container at /app/attachments so agents can read PDFs / images /
# docs the user sends via Signal.  REQUIRED for attachment handling — if
# unset, docker-compose falls back to /dev/null and attachments fail with
# "document not found".  Typical value: ~/.local/share/signal-cli/attachments
SIGNAL_ATTACHMENT_PATH=/Users/YOUR_USER/.local/share/signal-cli/attachments

# ─── Gateway ─────────────────────────────────────────────
GATEWAY_SECRET=generate_a_64_char_random_string_here
GATEWAY_PORT=8765
GATEWAY_BIND=127.0.0.1                # NEVER change to 0.0.0.0

# ─── Memory stack (Mem0 / pgvector / Neo4j) ─────────────
# REQUIRED — docker-compose refuses to start without these set.
# The installer (./install.sh) auto-generates strong values for both.
# Only edit manually if you're restoring an existing database.
MEM0_POSTGRES_PASSWORD=generate_a_64_char_random_string_here
MEM0_NEO4J_PASSWORD=generate_a_64_char_random_string_here

# ─── Models ──────────────────────────────────────────────
COMMANDER_MODEL=claude-opus-4-6
SPECIALIST_MODEL=claude-sonnet-4-6

# ─── Multi-tier LLM Configuration ──────────────────────
# LLM_MODE: "local" (Ollama only), "cloud" (API only), "hybrid" (both, cascade)
LLM_MODE=hybrid

# COST_MODE: "budget" (cheapest), "balanced" (cost/quality), "quality" (best models)
COST_MODE=balanced

# API tier — frontier models via OpenRouter (DeepSeek, MiniMax, Kimi, GLM, Gemini)
# Get your key at https://openrouter.ai/keys
API_TIER_ENABLED=true
OPENROUTER_API_KEY=

# ─── Local LLM (Ollama) ─────────────────────────────────
# Install Ollama (https://ollama.com). Models are auto-pulled on first use.
# Only ONE model is loaded at a time — system swaps dynamically to save RAM.
# If Ollama is down, system falls back to Claude automatically.
LOCAL_LLM_ENABLED=true
LOCAL_LLM_BASE_URL=http://host.docker.internal:11434

# Role-based model assignment (each role gets the best model for its task)
LOCAL_MODEL_CODING=qwen3:30b-a3b       # fast code generation
LOCAL_MODEL_ARCHITECTURE=deepseek-r1:32b  # architecture, code review, debugging
LOCAL_MODEL_RESEARCH=qwen3:30b-a3b      # web research + synthesis
LOCAL_MODEL_WRITING=qwen3:30b-a3b       # docs, summaries, reports
LOCAL_MODEL_DEFAULT=qwen3:30b-a3b       # fallback for unspecified roles

# Vetting — Claude Opus 4.6 reviews ALL local LLM output before sending to user
VETTING_ENABLED=true
VETTING_MODEL=claude-sonnet-4.6

# ─── Docker Sandbox ──────────────────────────────────────
SANDBOX_IMAGE=crewai-sandbox:latest
SANDBOX_TIMEOUT_SECONDS=30
SANDBOX_MEMORY_LIMIT=512m
SANDBOX_CPU_LIMIT=0.5

# ─── Self-Improvement Schedule ───────────────────────────
SELF_IMPROVE_CRON=0 3 * * *           # Daily at 03:00
SELF_IMPROVE_TOPIC_FILE=workspace/skills/learning_queue.md

# ─── Cloud Backup (optional) ─────────────────────────────
# Set to a GitHub remote URL to enable automatic workspace backups.
# Backs up: skills/, conversations.db, learning_queue.md
# Excludes: memory/ (ChromaDB), output/, audit logs
#
# Option A — HTTPS with a Personal Access Token (PAT):
#   Create a PAT at https://github.com/settings/tokens (scope: repo)
#   Then set:
# WORKSPACE_BACKUP_REPO=https://<PAT>@github.com/yourname/crewai-memory-backup.git
#
# Option B — SSH (key must be available inside the container):
# WORKSPACE_BACKUP_REPO=git@github.com:yourname/crewai-memory-backup.git
#
# Leave commented out to disable (system works fine without it).
# WORKSPACE_BACKUP_REPO=

WORKSPACE_SYNC_CRON=0 * * * *        # Push to GitHub every hour

# ─── Email (IMAP/SMTP) ──────────────────────────────────
# Enable to let AndrusAI check, send, and organize email.
# Gmail: create App Password at https://myaccount.google.com/apppasswords
# Outlook: use your regular password or App Password
EMAIL_ENABLED=false
EMAIL_IMAP_HOST=imap.gmail.com
EMAIL_IMAP_PORT=993
EMAIL_SMTP_HOST=smtp.gmail.com
EMAIL_SMTP_PORT=587
EMAIL_ADDRESS=
EMAIL_PASSWORD=

# ─── SEC EDGAR (Financial Filings) ──────────────────────
# Free API, no key needed. SEC requires a User-Agent with contact email.
SEC_EDGAR_USER_AGENT=BotArmy/1.0 (your@email.com)

# ─── Conversation History ─────────────────────────────────
# How many recent message exchanges to inject into each new request.
# Lets the bot understand short/contextual replies like "yes", "try python",
# "what about last week?" without you repeating yourself.
CONVERSATION_HISTORY_TURNS=10
